@page
@model CarParts.Web.Pages.Parts.CreateModel
@{
    ViewData["Title"] = "Add Part";
}

<h1>Add Part</h1>
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Part.PartNumber" class="form-label"></label>
                <input asp-for="Part.PartNumber" class="form-control" />
                <span asp-validation-for="Part.PartNumber" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Part.Name" class="form-label"></label>
                <input asp-for="Part.Name" class="form-control" />
                <span asp-validation-for="Part.Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Part.Brand" class="form-label"></label>
                <input asp-for="Part.Brand" class="form-control" />
                <span asp-validation-for="Part.Brand" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Part.Quantity" class="form-label"></label>
                <input asp-for="Part.Quantity" class="form-control" />
                <span asp-validation-for="Part.Quantity" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Part.Price" class="form-label"></label>
                <input asp-for="Part.Price" class="form-control" />
                <span asp-validation-for="Part.Price" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
