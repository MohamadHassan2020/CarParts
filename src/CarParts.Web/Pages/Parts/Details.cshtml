@page "{id:int}"
@model CarParts.Web.Pages.Parts.DetailsModel
@{
    ViewData["Title"] = "Part Details";
}

<h1>Part Details</h1>
<dl class="row">
    <dt class="col-sm-2">Part Number</dt>
    <dd class="col-sm-10">@Model.Part.PartNumber</dd>
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Part.Name</dd>
    <dt class="col-sm-2">Brand</dt>
    <dd class="col-sm-10">@Model.Part.Brand</dd>
    <dt class="col-sm-2">Quantity</dt>
    <dd class="col-sm-10">@Model.Part.Quantity</dd>
    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Part.Price.ToString("C")</dd>
</dl>
<a asp-page="Edit" asp-route-id="@Model.Part.Id" class="btn btn-primary">Edit</a>
<a asp-page="Index" class="btn btn-secondary">Back</a>
